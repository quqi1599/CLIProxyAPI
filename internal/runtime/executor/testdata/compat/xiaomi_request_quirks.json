    {
      "name": "tool schema simplification belongs to policy",
      "model": "mimo-v2.5",
      "input": {
        "model": "configured-xiaomi-tool-alias",
        "messages": [
          {
            "role": "user",
            "content": "hi"
          }
        ],
        "tools": [
          {
            "type": "function",
            "function": {
              "name": "lookup",
              "strict": true,
              "parameters": {
                "type": "object",
                "properties": {
                  "query": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "null"
                      }
                    ]
                  }
                },
                "required": [
                  "query"
                ],
                "additionalProperties": false
              }
            }
          }
        ]
      },
      "expected": {
        "model": "configured-xiaomi-tool-alias",
        "messages": [
          {
            "role": "user",
            "content": "hi"
          }
        ],
        "tools": [
          {
            "type": "function",
            "function": {
              "name": "lookup",
              "parameters": {
                "type": "object",
                "properties": {
                  "query": {
                    "type": "string"
                  }
                },
                "required": [
                  "query"
                ]
              }
            }
          }
        ]
      },
      "downgrades": [
        "openai_compat.xiaomi.tool_schema_normalized"
      ]
    },
    {
