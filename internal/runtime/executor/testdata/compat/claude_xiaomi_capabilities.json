{
  "policy_id": "claude_compat.xiaomi.capability_scrub",
  "compat_kind": "xiaomi",
  "base_url": "https://token-plan-cn.xiaomimimo.com/anthropic",
  "cases": [
    {
      "name": "namespaced mimo v2.5 keeps native image",
      "model": "vendor/mimo-v2.5(high)",
      "input": {
        "model": "vendor/mimo-v2.5(high)",
        "messages": [
          {
            "role": "user",
            "content": [
              {"type": "text", "text": "inspect"},
              {"type": "image", "source": {"type": "base64", "media_type": "image/png", "data": "AAAA"}},
              {"type": "image_url", "image_url": {"url": "data:image/png;base64,BBBB"}}
            ]
          }
        ]
      },
      "expected": {
        "model": "vendor/mimo-v2.5(high)",
        "messages": [
          {
            "role": "user",
            "content": [
              {"type": "text", "text": "inspect"},
              {"type": "image", "source": {"type": "base64", "media_type": "image/png", "data": "AAAA"}}
            ]
          }
        ]
      },
      "downgrades": ["claude.tool_search_compatibility"]
    },
    {
      "name": "mimo v2.5 pro does not inherit image support",
      "model": "mimo-v2.5-pro",
      "input": {
        "model": "mimo-v2.5-pro",
        "messages": [
          {
            "role": "user",
            "content": [
              {"type": "text", "text": "inspect"},
              {"type": "image", "source": {"type": "base64", "media_type": "image/png", "data": "AAAA"}}
            ]
          }
        ]
      },
      "expected": {
        "model": "mimo-v2.5-pro",
        "messages": [
          {
            "role": "user",
            "content": [
              {"type": "text", "text": "inspect"}
            ]
          }
        ]
      },
      "downgrades": ["claude.tool_search_compatibility"]
    }
  ]
}
